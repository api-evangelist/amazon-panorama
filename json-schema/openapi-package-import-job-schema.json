{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-panorama/refs/heads/main/json-schema/openapi-package-import-job-schema.json",
  "title": "PackageImportJob",
  "description": "A job to import a package version.",
  "type": "object",
  "properties": {
